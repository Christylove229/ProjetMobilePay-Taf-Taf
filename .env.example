# Exemple de variables d'environnement pour Render
# Remplace les valeurs par celles de ton application.
DJANGO_SECRET_KEY=change_me_to_a_secure_value
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=ton-app-render.onrender.com
# DATABASE_URL est défini automatiquement par Render si tu utilises une base de données PostgreSQL gérée.
# Exemple local seulement :
# DATABASE_URL=postgres://username:password@hostname:5432/dbname
